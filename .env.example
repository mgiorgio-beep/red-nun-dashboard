# ============================================================
# Red Nun Dashboard — environment variables
# Copy to .env and fill in values. .env is gitignored.
# ============================================================

# --- Toast POS ---
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_RESTAURANT_GUID=
# Path to the live Toast SQLite database. Phase 2 cutover will move this to
# /var/lib/rednun/toast_data.db. During cutover it stays at /opt/rednun/toast_data.db.
TOAST_DB_PATH=/opt/rednun/toast_data.db

# --- 7shifts ---
SEVENSHIFTS_TOKEN=
SEVENSHIFTS_COMPANY_ID=

# --- QuickBooks Online ---
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REALM_ID=
QBO_ENVIRONMENT=production
QBO_TOKENS_PATH=/opt/red-nun-dashboard/integrations/quickbooks/tokens.json

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# --- Anthropic (for invoice OCR + bot) ---
ANTHROPIC_API_KEY=

# --- Google (Drive + Gmail watchers) ---
GOOGLE_CREDENTIALS_PATH=/opt/red-nun-dashboard/integrations/google/credentials.json
GMAIL_POLL_LABEL=
GOOGLE_DRIVE_FOLDER_ID=

# --- Flask ---
FLASK_SECRET_KEY=
SESSION_COOKIE_SECRET=

# --- DDNS ---
DDNS_HOSTNAME=
DDNS_TOKEN=

# --- Sonos ---
SONOS_AMP_IP=10.1.10.242

# --- Misc ---
FANZO_URL=
