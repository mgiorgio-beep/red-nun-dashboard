# ============================================================
# Red Nun Dashboard — environment variables
# Copy to .env and fill in values. .env is gitignored.
#
# Key names mirror /opt/rednun/.env, ~/rednun-agent/.env, and
# ~/.qb_env so the existing prod values can be merged in 1:1.
# Two restaurants (Dennis + Chatham) share one app instance.
# ============================================================

# --- Flask ---
SECRET_KEY=
DASHBOARD_PORT=8080

# --- Toast POS (shared creds, per-restaurant GUIDs) ---
TOAST_API_BASE_URL=https://ws-api.toasttab.com
TOAST_CLIENT_ID=
TOAST_CLIENT_SECRET=
TOAST_RESTAURANT_GUID_DENNIS=
TOAST_RESTAURANT_GUID_CHATHAM=
# Live SQLite DB. Phase 2 cutover moves this to /var/lib/rednun/toast_data.db.
# During cutover it stays at /opt/rednun/toast_data.db.
DB_PATH=/var/lib/rednun/toast_data.db

# --- 7shifts (per-restaurant tokens) ---
SEVENSHIFTS_TOKEN_DENNIS=
SEVENSHIFTS_TOKEN_CHATHAM=

# --- QuickBooks Online (was ~/.qb_env) ---
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REALM_ID=

# --- Anthropic (invoice OCR + Telegram bot) ---
ANTHROPIC_API_KEY=

# --- Telegram bot (was ~/rednun-agent/.env) ---
TELEGRAM_BOT_TOKEN=
ALLOWED_USERS=

# --- Google Drive (invoice watcher) ---
# OAuth client file lives at integrations/google/credentials.json (gitignored).
AVAILABILITY_FOLDER_ID=

# --- Gmail (invoice email poller + notifications) ---
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
INVOICE_EMAIL=
INVOICE_EMAIL_APP_PASSWORD=

# --- Cloudflare DDNS ---
CF_API_TOKEN=
CF_ZONE_ID=
CF_SSH_RECORD_ID=

# --- Sports / odds feeds ---
API_SPORTS_KEY=
ODDS_API_KEY=
FANZO_SESSION_COOKIE=

# --- TempStick (walk-in temperature sensor) ---
TEMPSTICK_API_KEY=

# --- Sonos ---
# Hardcoded in code today; override here if the Amp moves.
SONOS_AMP_IP=10.1.10.242

# ============================================================
# REMOVED in Phase 2 (do NOT add back):
#   MARGINEDGE_API_KEY  — MarginEdge integration retired
#   REPORT_RECIPIENTS   — weekly email report retired
# ============================================================
